# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=suspension_designer

# .NET API
ASPNETCORE_ENVIRONMENT=Development
CONNECTION_STRING=Host=localhost;Port=5432;Database=suspension_designer;Username=postgres;Password=postgres
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_ISSUER=SuspensionDesigner
JWT_AUDIENCE=SuspensionDesignerApp

# CORS (comma-separated origins for production)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:5000
